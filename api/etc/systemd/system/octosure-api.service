[Unit]
Description=Octosure API V2
After=network.target postgresql.service octosure-distribuidor.service
Wants=postgresql.service

[Service]
Type=simple
WorkingDirectory=/opt/octosure
EnvironmentFile=/opt/octosure/.env.octosure
ExecStart=/opt/octosure/.venv/bin/python -u /opt/octosure/V2/server.py
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
