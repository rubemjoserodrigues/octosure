server {
    listen 80;
    server_name octosure.net;
    return 301 https://$host$request_uri;

    location = /instalador.exe {
        alias /var/www/octosure.net/instalador.exe;
        default_type application/octet-stream;
        add_header Content-Disposition "attachment; filename=instalador.exe";
    }

    location = /updates/latest.yml {
        alias /var/www/octosure.net/updates/latest.yml;
        default_type text/yaml;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    location ^~ /updates/ {
        alias /var/www/octosure.net/updates/;
        autoindex off;
        try_files $uri =404;
    }
}

server {
    listen 443 ssl http2;
    server_name octosure.net;

    ssl_certificate /etc/letsencrypt/live/octosure.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/octosure.net/privkey.pem;

    root /opt/octosure;
    index index.php index.html;


    location = /instalador.exe {
        alias /var/www/octosure.net/instalador.exe;
        default_type application/octet-stream;
        add_header Content-Disposition "attachment; filename=instalador.exe";
    }

    location = /updates/latest.yml {
        alias /var/www/octosure.net/updates/latest.yml;
        default_type text/yaml;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    location ^~ /updates/ {
        alias /var/www/octosure.net/updates/;
        autoindex off;
        try_files $uri =404;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3005;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /socket.io/ {
        proxy_pass http://127.0.0.1:3005/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    location = / {
        return 302 /painel/;
    }

    location = /painel {
        return 301 /painel/;
    }

    location /painel/ {
        try_files $uri $uri/ /painel/index.php?$query_string;
    }

    location ~ ^/painel/.*\.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME /opt/octosure$fastcgi_script_name;
        include fastcgi_params;
    }
}
